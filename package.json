{
	"name": "uni-types",
	"description": "Universal TypeScript type utilities - A comprehensive collection of type helpers for TypeScript development",
	"type": "module",
	"version": "1.3.0",
	"packageManager": "pnpm@9.15.9",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"exports": {
		".": {
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"directories": {
		"dist": "dist",
		"src": "src"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"deploy": "sh scripts/deploy.sh",
		"clean": "rm -rf dist temp coverage",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint --fix .",
		"format": "prettier --write \"**/*.{js,ts,jsx,tsx,yml,json,md}\"",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@eslint-sets/eslint-config": "^6.3.1",
		"@guolao/vue-monaco-editor": "^1.6.0",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"@vitest/coverage-v8": "4.1.4",
		"eslint": "^9.39.4",
		"monaco-editor": "^0.55.1",
		"prettier": "^3.8.3",
		"prettier-config-common": "^1.5.0",
		"publint": "^0.3.18",
		"tsdown": "^0.21.9",
		"typescript": "^5.9.3",
		"vite": "^8.0.8",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.4"
	},
	"peerDependencies": {
		"@prisma/client": ">=5.0.0",
		"@trpc/server": ">=10.0.0",
		"react": ">=18.0.0",
		"vue": ">=3.0.0",
		"yup": ">=1.0.0",
		"zod": ">=3.0.0"
	},
	"peerDependenciesMeta": {
		"@prisma/client": {
			"optional": true
		},
		"@trpc/server": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"vue": {
			"optional": true
		},
		"yup": {
			"optional": true
		},
		"zod": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"sideEffects": false,
	"keywords": [
		"typescript",
		"types",
		"utility-types",
		"type-helpers",
		"pick",
		"omit",
		"partial",
		"required",
		"deep-partial",
		"deep-required",
		"type-utilities"
	],
	"license": "MIT",
	"author": "saqqdy <https://github.com/saqqdy>",
	"homepage": "https://github.com/saqqdy/uni-types#readme",
	"bugs": {
		"url": "https://github.com/saqqdy/uni-types/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saqqdy/uni-types.git"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	}
}